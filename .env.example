# Firebase Client Configurations for Web & Mobile App (REACT_APP_ prefix is required)
REACT_APP_FIREBASE_API_KEY=your_api_key_here
REACT_APP_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
REACT_APP_FIREBASE_PROJECT_ID=your_project_id
REACT_APP_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
REACT_APP_FIREBASE_APP_ID=your_app_id_here

# Device key proving this build is the trusted POS app (not the public
# customer website) — must match POS_DEVICE_KEY in whatsapp-relay/.env
# Generate with: openssl rand -hex 32
REACT_APP_POS_DEVICE_KEY=your_random_device_key_here
