rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Products: Customer website needs to read the menu; POS writes product changes
    match /products/{productId} {
      allow read:  if true;
      allow write: if true;
    }

    // Orders: Customers create orders; POS reads/updates status; nobody deletes
    match /orders/{orderId} {
      allow create: if true;
      allow read:   if true;
      allow update: if true;
      allow delete: if false;
    }

    // Settings: Customer website reads for offers/delivery; POS writes
    match /settings/{docId} {
      allow read:  if true;
      allow write: if true;
    }

    // Sales history: POS syncs here for cross-device reports
    // No public read — your revenue data should not be exposed to the internet
    match /sales/{saleId} {
      allow write: if true;
      allow read:  if false;
    }

    // Spendings: POS syncs here for cross-device reports
    match /spendings/{spendingId} {
      allow write: if true;
      allow read:  if false;
    }
  }
}
