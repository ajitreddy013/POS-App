rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Staff = the POS app, authenticated anonymously and granted a custom
    // claim by whatsapp-relay's /auth/grant-staff endpoint after verifying
    // a device key baked into the POS build. The public customer website
    // never receives this claim.
    function isStaff() {
      return request.auth != null && request.auth.token.staff == true;
    }

    // Products: Customer website needs to read the menu; only POS (staff) writes
    match /products/{productId} {
      allow read:  if true;
      allow write: if isStaff();
    }

    // Orders: Customers create orders with no login; POS (staff) reads and
    // updates status; nobody deletes. Reads are staff-only — public order
    // tracking (flipping from a temp ticket to the real W-N/A-N number) goes
    // through whatsapp-relay's /order/ticket-status endpoint (Admin SDK,
    // returns only the order number) instead of a direct client read, so the
    // full orders collection (customer PII, cost/profit) is never publicly
    // enumerable.
    match /orders/{orderId} {
      allow create: if true;
      allow read:   if isStaff();
      allow update: if isStaff();
      allow delete: if false;
    }

    // Settings: Customer website reads for offers/delivery; only POS (staff) writes
    match /settings/{docId} {
      allow read:  if true;
      allow write: if isStaff();
    }

    // Sales history: internal reports, staff-only in both directions
    match /sales/{saleId} {
      allow read, write: if isStaff();
    }

    // Spendings: internal reports, staff-only in both directions
    match /spendings/{spendingId} {
      allow read, write: if isStaff();
    }

    // Registered POS devices — staff-only (previously had no rule at all,
    // so this write was already silently failing before this change)
    match /admin_devices/{deviceId} {
      allow read, write: if isStaff();
    }
  }
}
