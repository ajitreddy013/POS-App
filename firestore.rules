rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Products Menu: Anyone can read; write allowed for syncing
    match /products/{productId} {
      allow read: if true;
      allow write: if true;
    }
    
    // Orders Pipeline: Customers can create/read; admin/servers can update status
    match /orders/{orderId} {
      allow create, read, update: if true;
      allow delete: if false; // Orders should never be deleted, only cancelled
    }

    // Settings: Public read for customer website; write allowed for POS app syncing
    match /settings/{docId} {
      allow read, write: if true;
    }
  }
}
