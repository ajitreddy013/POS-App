# Server Port
PORT=8080

# Firebase Admin Service Account Credentials (needed for webhook Firestore updates)
FIREBASE_PROJECT_ID=counterflow-kiosk
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@counterflow-kiosk.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvgIBADANBgkqhkiG9w0BAQEFAASCBKgwggSkAgEAAoIBAQC...\"

# Device key proving a request to /auth/grant-staff came from the trusted
# POS app build — must match REACT_APP_POS_DEVICE_KEY in the root .env
# Generate with: openssl rand -hex 32
POS_DEVICE_KEY=your_random_device_key_here
